# 依赖
node_modules

# 构建产物
dist
dist-ssr
*.local
# 生产模式下拷到后端的前端产物（由 web/dist 拷贝而来，不提交）
server/static/

# 日志
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# 本地配置 / 密钥
.env
.env.*
.claude/settings.local.json

# 编辑器与系统文件
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.sw?
*.db
# SQLite 备份 / 临时文件（如 xiaozhu.db.bak、xiaozhu.db-wal），都不该入库
*.db.*
*.db-journal
*.db-wal
*.db-shm