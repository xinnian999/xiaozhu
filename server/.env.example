# .env —— 本地开发配置（不要提交到 git！）
#
# ★ 配置已「尽量入库」：下面除 JWT_SECRET / DATABASE_URL 外的所有项，
#   都可以改在管理后台 /admin 里维护（存进数据库 app_settings / llm_groups 表）。
#   两种用法二选一：
#     (a) 留空 .env，首次启动后去 /admin 填 —— 真正做到「.env 几乎为空」。
#     (b) 在这里填好，首次启动会自动「导入」进库（之后以库为准，改动请去 /admin）。
#   ⚠️ JWT_SECRET、DATABASE_URL 是「根密钥 / 库位置」，有循环依赖，必须留在 .env，永不入库。

# 【必填，永不入库】JWT 签名密钥 —— token 防伪造的根本。绝不能提交真实值。
# 用 `python -c "import secrets; print(secrets.token_urlsafe(48))"` 生成一串随机值。
JWT_SECRET=your_random_secret_here

# 【可选，永不入库】覆盖数据库路径
# DATABASE_URL=sqlite+aiosqlite:///./xiaozhu.db

# ────────────────────────────────────────────────────────────────────────
# 以下均为「可入库」项：填了会在首次启动导入库；之后请在 /admin 里改。
# ────────────────────────────────────────────────────────────────────────

# 中转站地址（OpenAI 兼容端点，所有分组的默认 base_url；不填则用官方 api.openai.com）
OPENAI_BASE_URL=https://your-proxy.example.com/v1

# 分组 api_key —— 中转站按「分组」发不同的 key，每个分组一个变量。
# 首次启动会按分组导入到 llm_groups 表；之后在 /admin →「模型分组」里改。
API_KEY_QWEN=your_qwen_group_key_here
# API_KEY_CLAUDE=your_claude_group_key_here

# ── 个人收款码（微信/支付宝）+ 订单通知 ──────────────────────────────
# 收款是「手动核对」模式：用户扫码付款后点「我已支付」，订单转待审核，你在后台人工放行升档。
# 下面这些也可以不写进 .env，改由 /admin →「配置」页填（收款码支持后台上传图片）。
# 收款码图片建议用后台上传（存 data URI）；这里留空即可。
PAY_QR_WECHAT=
PAY_QR_ALIPAY=
PAY_PAYEE_NAME=
# 联系方式（微信号/QQ/邮箱等）：展示在「待审核」页，方便用户在你没及时审核时联系你。
PAY_CONTACT=
# 新订单通知收件邮箱；留空则发到 SMTP_USER（发验证码的那个邮箱）。
ORDER_NOTIFY_EMAIL=

# ── 邮件 SMTP（发注册验证码）—— smtp_password 填邮箱「授权码」，不是登录密码 ──
# QQ邮箱:  smtp.qq.com   端口 465  授权码在「设置→账户→POP3/SMTP→生成授权码」
# 163邮箱: smtp.163.com  端口 465  授权码在「设置→POP3/SMTP/IMAP」
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM_NAME=小筑

