# .env —— 本地开发配置（不要提交到 git！）

# 中转站地址（OpenAI 兼容端点，所有分组共用一个 base_url；不填则用官方 api.openai.com）
OPENAI_BASE_URL=https://your-proxy.example.com/v1

# 分组 api_key —— 中转站按「分组」发不同的 key，每个分组一个变量。
# 只配了哪个分组的 key，哪个分组的模型才可用；没配的分组调用时会明确报错。
API_KEY_QWEN=your_qwen_group_key_here
# API_KEY_CLAUDE=your_claude_group_key_here

# JWT 签名密钥 —— 必填，token 防伪造的根本。绝不能提交真实值。
# 用 `python -c "import secrets; print(secrets.token_urlsafe(48))"` 生成一串随机值。
JWT_SECRET=your_random_secret_here

# 可选：覆盖数据库路径
# DATABASE_URL=sqlite+aiosqlite:///./vibuild.db
