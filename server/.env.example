# .env —— 本地开发配置（不要提交到 git！）

# OpenAI 兼容协议的 API Key（可以是 OpenAI 官方 key，也可以是中转 key）
OPENAI_API_KEY=your_api_key_here

# 可选：覆盖默认模型
# LLM_MODEL=claude-sonnet-4-5

# 可选：OpenAI 兼容端点地址（不填则用官方 api.openai.com）
OPENAI_BASE_URL=https://your-proxy.example.com/v1

# 可选：覆盖数据库路径
# DATABASE_URL=sqlite+aiosqlite:///./vibuild.db
