# .env —— 本地开发配置（不要提交到 git！）

# 中转站地址（OpenAI 兼容端点，所有分组共用一个 base_url；不填则用官方 api.openai.com）
OPENAI_BASE_URL=https://your-proxy.example.com/v1

# 分组 api_key —— 中转站按「分组」发不同的 key，每个分组一个变量。
# 只配了哪个分组的 key，哪个分组的模型才可用；没配的分组调用时会明确报错。
API_KEY_QWEN=your_qwen_group_key_here
# API_KEY_CLAUDE=your_claude_group_key_here

# JWT 签名密钥 —— 必填，token 防伪造的根本。绝不能提交真实值。
# 用 `python -c "import secrets; print(secrets.token_urlsafe(48))"` 生成一串随机值。
JWT_SECRET=your_random_secret_here

# 可选：覆盖数据库路径
# DATABASE_URL=sqlite+aiosqlite:///./xiaozhu.db

# ── 爱发电（afdian / ifdian.net）—— 值在 https://ifdian.net/dashboard/dev 和创作者后台拿 ──
# 创作者 user_id（开发者后台「user_id」一栏）
AFDIAN_USER_ID=your_afdian_user_id
# API Token（开发者后台「生成」按钮，密钥，切勿提交仓库）
AFDIAN_TOKEN=your_afdian_token
# 两个会员商品的 plan_id（= 商品 item_id）和各自 sku_id（型号 id）
AFDIAN_PRO_PLAN_ID=your_pro_plan_id
AFDIAN_PRO_SKU_ID=your_pro_sku_id
AFDIAN_MAX_PLAN_ID=your_max_plan_id
AFDIAN_MAX_SKU_ID=your_max_sku_id
# 线上公网域名（不带末尾斜杠）；webhook 在爱发电后台配成 https://<域名>/api/billing/notify/afdian
AFDIAN_PUBLIC_BASE=https://your-domain.com

# ── 邮件 SMTP（发注册验证码）—— smtp_password 填邮箱「授权码」，不是登录密码 ──
# QQ邮箱:  smtp.qq.com   端口 465  授权码在「设置→账户→POP3/SMTP→生成授权码」
# 163邮箱: smtp.163.com  端口 465  授权码在「设置→POP3/SMTP/IMAP」
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM_NAME=小筑
